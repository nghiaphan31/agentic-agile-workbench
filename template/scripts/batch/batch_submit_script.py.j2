import sys
import os
from pathlib import Path

# Ensure workspace root is on path
WS_ROOT = Path(__file__).parent.parent.parent
sys.path.insert(0, str(WS_ROOT))

from scripts.batch import BatchConfig, submit_batch


def main() -> int:
    config_path = Path(__file__).parent / "{{ yaml_path }}"
    print(f"[{{ name }}] Loading config: {config_path}")

    config = BatchConfig.from_yaml(config_path)

    errors = config.validate()
    if errors:
        print("[{{ name }}] Config validation failed:", file=sys.stderr)
        for e in errors:
            print(f"  - {e}", file=sys.stderr)
        return 1

    try:
        batch = submit_batch(config)
        print(f"\n[{{ name }}] Done. Batch ID: {batch.id}")
        print(f"[{{ name }}] Run retrieve script when ready:")
        print(f"    python {Path(__file__).parent / '{{ retrieve_script_name }}'}")
        return 0
    except Exception as e:
        print(f"[{{ name }}] ERROR: {e}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    sys.exit(main())
